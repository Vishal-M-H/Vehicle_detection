# ---- Dataset (too large for GitHub) ----
data/train/
data/valid/
data/test/
*.zip
*.tar.gz
*.tar
*.rar

# ---- Logs ----
*.log
logs/

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- Misc ----
tmp/
temp/
*.bak
